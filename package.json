{
  "name": "home-helper",
  "version": "1.0.1",
  "description": "Network troubleshooting helper — built for Mom & Dad by Alec",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.alec.homehelper",
    "productName": "Home Helper",
    "copyright": "Copyright © 2024 Alec Farmer",
    "afterSign": "scripts/afterSign.js",
    "mac": {
      "category": "public.app-category.utilities",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ]
    },
    "dmg": {
      "title": "Home Helper",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "alecfarmer",
      "repo": "home-helper"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ]
  }
}
